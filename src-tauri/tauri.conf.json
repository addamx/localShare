{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalShare",
  "version": "0.1.0",
  "identifier": "com.localshare.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LocalShare",
        "width": 1360,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity"
  }
}
